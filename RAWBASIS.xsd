	</xs:element>
	<xs:annotation>
		<xs:documentation>
    ================== Groep versiecodering ===============================
    </xs:documentation>
	</xs:annotation>
	<xs:element name="versie.id">
		<xs:annotation>
			<xs:documentation>de unieke ID voor elk element</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="versie.laatste.mutatie" type="xs:date">
		<xs:annotation>
			<xs:documentation>Datum waarop de informatie waarop de versie informatie betrekking heeft, voor de laatste keer is gemuteerd</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="versie.datum" type="xs:date">
		<xs:annotation>
			<xs:documentation>Datum waarop de status is vastgesteld (c.q. de informatie in deze status is gepubliceerd)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="versie.status" default="concept">
		<xs:annotation>
			<xs:documentation>Status van de versie</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="verplicht"/>
				<xs:enumeration value="concept"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="versie.jaarversie" type="xs:string">
		<xs:annotation>
			<xs:documentation>Geeft de jaarversie aan (jjjj-mm formaat)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="versie.release">
		<xs:annotation>
			<xs:documentation>Geeft de versie van tussentijdse updates aan (jj-mm formaat)</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:length value="7"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="versie.kenmerk.nieuw">
		<xs:annotation>
			<xs:documentation>Element dat aangeeft dat een beschijving nieuw is vanaf de datum van publicatie</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="versie.datum" minOccurs="0"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="versie.kenmerk.vervang">
		<xs:annotation>
			<xs:documentation>Element dat aangeeft dat de informatie waarop de versie informatie betrekking heeft, andere reeds aanwezige informatie vervangt</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:choice>
					<xs:element ref="verwijzing.bepaling"/>
					<xs:element ref="verwijzing.catalogus"/>
					<xs:element ref="verwijzing.proef"/>
					<xs:element ref="verwijzing.handleiding"/>
				</xs:choice>
				<xs:element ref="versie.datum.verwijzing"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="versie.kenmerk.vervallen">
		<xs:annotation>
			<xs:documentation>Element met datum dat aangeeft dat een beschrijving vervallen is op de atum van publicatie</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="versie.datum" minOccurs="0"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="versie.datum.verwijzing" type="xs:string">
		<xs:annotation>
			<xs:documentation>Versiedatum in de verwijzing (jjjj-mm)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="versie.datum.vorig">
		<xs:annotation>
			<xs:documentation>Versiedatum van de vorige versie van de gepubliceerde data</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="versie.nummering">
		<xs:annotation>
			<xs:documentation>Element dat de elementen bevat met betrekking tot de versie-nummering</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="versie.nummer"/>
				<xs:element ref="versie.nummer.vorig"/>
				<xs:element ref="versie.datum"/>
				<xs:element ref="versie.datum.vorig"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="versie.nummer.vorig">
		<xs:annotation>
			<xs:documentation>Versienummer van de vorige versie</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="versie.nummer">
		<xs:annotation>
			<xs:documentation>Versienummer van de actuele versie</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="versie.informatie">
		<xs:annotation>
			<xs:documentation>Groep elementen met alle versie informatie</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="versie.datum"/>
				<xs:element ref="versie.nummering"/>
				<xs:element ref="versie.id"/>
				<xs:element ref="versie.status"/>
				<xs:element ref="versie.jaarversie"/>
				<xs:element ref="versie.release"/>
				<xs:element ref="versie.laatste.mutatie"/>
				<xs:element ref="versie.kenmerk.vervallen" minOccurs="0"/>
				<xs:element ref="versie.kenmerk.nieuw" minOccurs="0"/>
				<xs:element ref="versie.kenmerk.vervang" minOccurs="0"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:annotation>
		<xs:documentation>
    ================== Groepen algemene elementen ===============================
    </xs:documentation>
	</xs:annotation>
	<xs:element name="versie.info.boom">
		<xs:annotation>
			<xs:documentation>verkorte versie-informatie voor elementen uit de verschllende delen van de systematiek, standaard, cat. resultaatsbeschrivingen en cat.bepalingen</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="versie.id"/>
				<xs:element ref="versie.release"/>
				<xs:element ref="versie.jaarversie"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:annotation/>
	<xs:group name="grp.begrip">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op begrippen</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="begrip"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.verwijzingen">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op verwijzingen</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="verwijzing.bepaling"/>
			<xs:element ref="verwijzing.proef"/>
			<xs:element ref="verwijzing.catalogus"/>
			<xs:element ref="verwijzing.handleiding"/>
			<xs:element ref="verwijzing.extern"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.lists">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op opsommingen</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="ul"/>
			<xs:element ref="ol"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.lists.eenvoudig">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op eenvoudige opsommingen</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="ul.eenvoudig"/>
			<xs:element ref="ol.eenvoudig"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.lists.catalogus">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op opsommingen in de catalogus</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="ul.catalogus"/>
			<xs:element ref="ol.catalogus"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.tables">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op de diverse onderdelen van tabellen</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element ref="tabel.aanduiding" minOccurs="0"/>
			<xs:element ref="table"/>
			<xs:element ref="tabel.voettekst" minOccurs="0"/>
		</xs:sequence>
	</xs:group>
	<xs:group name="grp.regelopmaak">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op de regelopmaak</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="br"/>
			<xs:element ref="em"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.figuur">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op figuren</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="img" maxOccurs="unbounded"/>
			<xs:element ref="figuur.naam" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:group>
	<xs:group name="grp.supersub">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op het super / sub weergeven van tekst</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="sup" maxOccurs="unbounded"/>
			<xs:element ref="sub" maxOccurs="unbounded"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.koppen">
		<xs:annotation>
			<xs:documentation>Groep met elementen met koppen deze kunnen worden gebruikt in proeven en bijlagen</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="kop.1"/>
			<xs:element ref="kop.2"/>
			<xs:element ref="kop.3"/>
			<xs:element ref="kop.4"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.bestekschrijver">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op onderdelen die door bestekschrijvers kunnen worden ingevuld</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="bestekschrijvers.invultekst" maxOccurs="unbounded"/>
			<xs:element ref="bestekschrijvers.vrijetekst" maxOccurs="unbounded"/>
		</xs:choice>
	</xs:group>
	<xs:annotation>
		<xs:documentation>
    ================== Groep tekstblok =====================  
   </xs:documentation>
	</xs:annotation>
	<xs:complexType name="tekstblok.vrij" mixed="true">
		<xs:annotation>
			<xs:documentation>Elementen van dit type kunnen diverse andere opmaakelementen bevatten, dit tekstblok kan tevens 4 niveaus van koppen bevatten ivm proeven en bijlagen bij hoofdstukken</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.lists"/>
			<xs:group ref="grp.verwijzingen"/>
			<xs:group ref="grp.tables"/>
			<xs:group ref="grp.figuur"/>
			<xs:group ref="grp.regelopmaak"/>
			<xs:group ref="grp.supersub"/>
			<xs:element ref="formule"/>
			<xs:group ref="grp.koppen"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.hnl" mixed="true">
		<xs:annotation>
			<xs:documentation>Elementen van dit type kunnen diverse andere opmaakelementen bevatten, dit tekstblok kan tevens 4 niveaus van koppen bevatten</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.lists"/>
			<xs:group ref="grp.tables"/>
			<xs:group ref="grp.figuur"/>
			<xs:group ref="grp.regelopmaak"/>
			<xs:group ref="grp.verwijzingen"/>
			<xs:group ref="grp.supersub"/>
			<xs:group ref="grp.koppen"/>
			<xs:element ref="formule"/>
			<xs:element ref="citaat"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.uitgebreid.std" mixed="true">
		<xs:annotation>
			<xs:documentation>Elementen van dit type kunnen diverse andere opmaakelementen bevatten, aanwijzingsteksten kunnen hier niet worden toegepast</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:element ref="begrip"/>
			<xs:group ref="grp.lists"/>
			<xs:group ref="grp.verwijzingen"/>
			<xs:group ref="grp.tables"/>
			<xs:group ref="grp.figuur"/>
			<xs:group ref="grp.regelopmaak"/>
			<xs:group ref="grp.supersub"/>
			<xs:element ref="formule"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.uitgebreid" mixed="true">
		<xs:annotation>
			<xs:documentation>Elementen van dit type kunnen diverse andere opmaakelementen bevatten, verschil met tekstblok.uitgebreid-stand  is dat hier aanwijzingstekst kan worden toegepast</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.begrip"/>
			<xs:group ref="grp.lists"/>
			<xs:group ref="grp.verwijzingen"/>
			<xs:group ref="grp.tables"/>
			<xs:group ref="grp.figuur"/>
			<xs:group ref="grp.regelopmaak"/>
			<xs:group ref="grp.supersub"/>
			<xs:element ref="formule"/>
			<xs:element ref="aanwijzings.tekst"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.eenvoudig" mixed="true">
		<xs:annotation>
			<xs:documentation>Elementen van dit type kunnen diverse andere elementen bevatten</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.regelopmaak"/>
			<xs:group ref="grp.supersub"/>
			<xs:group ref="grp.lists.catalogus"/>
			<xs:group ref="grp.verwijzingen"/>
			<xs:element ref="bouwstof"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.catalogus" mixed="true">
		<xs:annotation>
			<xs:documentation>De vaste en variabele teksten binnen een deficode</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:element ref="aanwijzings.tekst"/>
			<xs:element ref="bestekschrijvers.invultekst"/>
			<xs:element ref="bestekschrijvers.vrijetekst"/>
			<xs:element ref="bouwstof"/>
			<xs:group ref="grp.verwijzingen"/>
			<xs:group ref="grp.regelopmaak"/>
			<xs:group ref="grp.supersub"/>
			<xs:group ref="grp.lists.catalogus"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.naamlang" mixed="true">
		<xs:annotation>
			<xs:documentation>De elementen die voor kunnen komen in de naam van een artikel, een figuur, een proef of een tabel.</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.supersub"/>
			<xs:group ref="grp.regelopmaak"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.lijst.cat.res" mixed="true">
		<xs:annotation>
			<xs:documentation>Elementen van dit type worden toegepast in opsommingen.
</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.verwijzingen"/>
			<xs:group ref="grp.tables"/>
			<xs:group ref="grp.regelopmaak"/>
			<xs:group ref="grp.supersub"/>
			<xs:group ref="grp.bestekschrijver"/>
			<xs:element ref="aanwijzings.tekst"/>
			<xs:element ref="bouwstof"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="hoofdcode.hoofdtekst" mixed="true">
		<xs:annotation>
			<xs:documentation>Complextype voor de resultaatbeschrijving's hoofdcode.hoofdtekst</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.supersub"/>
			<xs:group ref="grp.regelopmaak"/>
			<xs:element ref="bestekschrijvers.vrijetekst"/>
			<xs:element name="aanwijzings.tekst" type="hoofdtekst.aanwijzings.tekst"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="hoofdtekst.aanwijzings.tekst" mixed="true">
		<xs:annotation>
			<xs:documentation>Aanwijzingstekst binnen een hoofdtekst</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.regelopmaak"/>
			<xs:group ref="grp.supersub"/>
			<xs:group ref="grp.lists.eenvoudig"/>
			<xs:group ref="grp.verwijzingen"/>
		</xs:choice>
	</xs:complexType>
	<xs:annotation>
		<xs:documentation>
    ================== Semantische elementen =====================  
   </xs:documentation>
	</xs:annotation>
	<xs:element name="kop.1">
		<xs:annotation>
			<xs:documentation>Kop van niveau 1 (t.b.v. proeven, bijlagen en de handleiding)</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:complexContent>
				<xs:extension base="tekstblok.naamlang">
					<xs:attribute ref="guid"/>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="kop.2">
		<xs:annotation>
			<xs:documentation>Kop van niveau 2 (t.b.v. proeven, bijlagen en de handleiding)</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:complexContent>
				<xs:extension base="tekstblok.naamlang">
					<xs:attribute ref="guid"/>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="kop.3">
		<xs:annotation>
			<xs:documentation>Kop van niveau 3 (t.b.v. proeven, bijlagen en de handleiding)</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:complexContent>
				<xs:extension base="tekstblok.naamlang">
					<xs:attribute ref="guid"/>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="kop.4">
		<xs:annotation>
			<xs:documentation>Kop van niveau 4 (t.b.v. proeven, bijlagen en de handleiding)</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:complexContent>
				<xs:extension base="tekstblok.naamlang">
					<xs:attribute ref="guid"/>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="begrip">
