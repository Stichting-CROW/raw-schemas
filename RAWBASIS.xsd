								<xs:enumeration value="top,right,bottom"/>
								<xs:enumeration value="top,left,right"/>
								<xs:enumeration value="top,right,left"/>
								<xs:enumeration value="top,bottom,right"/>
								<xs:enumeration value="bottom,right,left"/>
								<xs:enumeration value="bottom,left,right"/>
								<xs:enumeration value="bottom,top,left"/>
								<xs:enumeration value="bottom,left,top"/>
								<xs:enumeration value="bottom,top,right"/>
								<xs:enumeration value="bottom,right,top"/>
								<xs:enumeration value="bottom,top,left"/>
								<xs:enumeration value="top,left,bottom,right"/>
								<xs:enumeration value="top,bottom,left,right"/>
								<xs:enumeration value="top,bottom,right,left"/>
								<xs:enumeration value="top,left,right,bottom"/>
								<xs:enumeration value="top,left,bottom,right"/>
								<xs:enumeration value="top,right,left,bottom"/>
								<xs:enumeration value="top,right,bottom,left"/>
								<xs:enumeration value="bottom,top,right,left"/>
								<xs:enumeration value="bottom,top,left,right"/>
								<xs:enumeration value="bottom,right,left,top"/>
								<xs:enumeration value="bottom,right,top,left"/>
								<xs:enumeration value="bottom,left,top,right"/>
								<xs:enumeration value="bottom,left,right,top"/>
								<xs:enumeration value="left,right,top,bottom"/>
