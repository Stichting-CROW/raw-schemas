			<xs:documentation>Samengesteld element bestaande uit de naam van het begrip en de beschrijving ervan</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="begrip.naam"/>
				<xs:element ref="begrip.beschrijving" minOccurs="0"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="begrip.beschrijving" type="tekstblok.uitgebreid.std">
		<xs:annotation>
			<xs:documentation>Beschrijving van een begrip</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="begrip.naam" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>Naam van het begrip</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="aanwijzings.tekst" type="hoofdtekst.aanwijzings.tekst">
		<xs:annotation>
			<xs:documentation>Element waarmee aanwijzingen kunnen worden toegevoegd</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="deel.naam" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>Element waarmee de naam van een besteksdeel kan worden aangegeven</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="citaat" type="tekstblok.hnl">
		<xs:annotation>
			<xs:documentation>Element waarmee kan worden aangegeven dat de inhoud een citaat is</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:annotation>
		<xs:documentation>
    ================== Systeemgebonden algemene elementen =====================  
 </xs:documentation>
	</xs:annotation>
	<xs:element name="eenheid">
		<xs:annotation>
			<xs:documentation>Eenheid bij een hoeveelheid</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:minLength value="0"/>
				<xs:maxLength value="4"/>
				<xs:pattern value="([a-zA-Z1-9*/])*"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:annotation>
		<xs:documentation>
    ================== Elementen met verwijzingen binnen de systematiek ===========  
  </xs:documentation>
	</xs:annotation>
	<xs:annotation>
		<xs:documentation>Verwijzingen naar en binnen de Standaard, het ABB of Deel 3 van een bestek</xs:documentation>
	</xs:annotation>
	<xs:annotation>
		<xs:documentation>Attributen die worden gebruikt binnen de verwijzingen binnen de Standaard, het ABB of Deel 3 van een bestek</xs:documentation>
	</xs:annotation>
	<xs:attribute name="hfd" type="gen.codetweecijferalgemeen">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een hoofdstuknummer</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="dlhfd" type="gen.codeeencijferalgemeen">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een deelhoofdstuknummer</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="par" type="gen.codeeencijferspeciaal">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een paragraafnummer</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="art" type="gen.codetweecijferalgemeen">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een artikelnummer</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="lid">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een lid.nr</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="ann">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een annotatienummer</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="tbl">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een tabelnummer</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="fig">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een figuurnummer</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:minLength value="1"/>
				<xs:maxLength value="2"/>
				<xs:pattern value="[0-9][0-9]*"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="prf" type="xs:string">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een proefnummer</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="documentsoortbepaling" default="standaard">
		<xs:annotation>
			<xs:documentation>Attribuut waarmee wordt aangegeven in wat voor een soort document de bepaling waarnaar wordt verwezen voorkomt:
- standaard (de Standaard)
- abb (het algemeen besteksbestand)
- bestek (deel 3 van het bestek)</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="standaard"/>
				<xs:enumeration value="abb"/>
				<xs:enumeration value="bestek"/>
				<xs:enumeration value="catalogus bepalingen"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:element name="verwijzing.bepaling">
		<xs:annotation>
			<xs:documentation>Verwijzing naar hoofstuk, deelhoofdstuk, artikel paragraaf, lid, tabel, figuur of annotatie in de Standaard, het ABB of deel 3 van een bestek</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attribute ref="documentsoortbepaling" use="optional"/>
					<xs:attribute name="hfd" use="required"/>
					<xs:attribute name="dlhfd" use="optional"/>
					<xs:attribute name="par" use="optional"/>
					<xs:attribute name="art" use="optional"/>
					<xs:attribute name="lid" use="optional"/>
					<xs:attribute name="tbl" use="optional"/>
					<xs:attribute name="fig" use="optional"/>
					<xs:attribute name="ann" use="optional"/>
					<xs:attribute ref="prf"/>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="verwijzing.proef">
		<xs:annotation>
			<xs:documentation>Verwijzing naar een proef of een figuur bij een proef in de Standaard, het ABB of deel 3 van een bestek</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attribute name="documentsoortbepaling" use="required"/>
					<xs:attribute name="prf" use="required"/>
					<xs:attribute name="fig" use="optional"/>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="verwijzing.extern">
		<xs:annotation>
			<xs:documentation>Verwijzing naar een extern document</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attribute name="externsoort" use="required">
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="norm"/>
								<xs:enumeration value="administratievevoorwaarden"/>
								<xs:enumeration value="aanbestedingsreglement"/>
								<xs:enumeration value="anders"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:attribute>
					<xs:attribute name="extern_uri" type="xs:anyURI" use="optional">
						<xs:annotation>
							<xs:documentation>Hier kan een verwijzing naar de URI van een extern document worden ingegeven (bijvoorbeeld http://www.uav1989.nl/paragraaf.aspx?p=1)</xs:documentation>
						</xs:annotation>
					</xs:attribute>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:annotation>
		<xs:documentation>Verwijzingen naar en binnen de Catalogus</xs:documentation>
	</xs:annotation>
	<xs:attribute name="wcat" type="gen.codetweecijferspeciaal">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een werkcategorienummer</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="subwcat" type="gen.codetweecijferalgemeen">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar een subwerkcategorienummer</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="vlgnr">
		<xs:annotation>
			<xs:documentation>Attribuut dat verwijst naar het volgnummer van een resultaatsbeschrijving</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="tabposities">
		<xs:annotation>
			<xs:documentation>attribuut dat mogelijkheid bied tabposities uit te wisselen</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:element name="verwijzing.catalogus">
		<xs:annotation>
			<xs:documentation>Verwijzing naar een werkcategorie, een subwerkcategorie of een hoofdcode in de catalogus</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attribute name="wcat" use="required"/>
					<xs:attribute name="subwcat" use="optional"/>
					<xs:attribute name="vlgnr" use="optional"/>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:annotation>
		<xs:documentation>Verwijzingen naar en binnen de Handleiding</xs:documentation>
	</xs:annotation>
	<xs:element name="verwijzing.handleiding">
		<xs:annotation>
			<xs:documentation>Verwijzing naar de Handleiding</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attribute ref="hfd" use="optional"/>
					<xs:attribute ref="dlhfd" use="optional"/>
					<xs:attribute ref="parguid"/>
					<xs:attribute ref="kop1guid"/>
					<xs:attribute ref="kop2guid"/>
					<xs:attribute ref="kop3guid"/>
					<xs:attribute ref="kop4guid"/>
					<xs:attribute ref="hnltekstguid"/>
					<xs:attribute ref="bijlageguid"/>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:attribute name="parguid" type="guid">
		<xs:annotation>
			<xs:documentation>De guid van de paragraaf waarnaar wordt verwezen</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="kop1guid" type="guid">
		<xs:annotation>
			<xs:documentation>De guid van kop1 waarnaar wordt verwezen</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="kop2guid" type="guid">
		<xs:annotation>
			<xs:documentation>De guid van kop3 waarnaar wordt verwezen</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="kop3guid" type="guid">
		<xs:annotation>
			<xs:documentation>De guid van kop3 waarnaar wordt verwezen</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="kop4guid" type="guid">
		<xs:annotation>
			<xs:documentation>De guid van kop4 waarnaar wordt verwezen</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="hnltekstguid" type="guid">
		<xs:annotation>
			<xs:documentation>De guid van hnl.tekst waarnaar wordt verwezen</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="bijlageguid" type="guid">
		<xs:annotation>
			<xs:documentation>De guid van een bijlage in de handleiding waarnaar wordt verwezen</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:annotation>
		<xs:documentation>
    ================== Systeemgebonden artikel elementen =====================  
 </xs:documentation>
	</xs:annotation>
	<xs:element name="hoofdstuk.nr0109">
		<xs:annotation>
			<xs:documentation>Nummer van een hoofdstuk van 01 t/m 09. </xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:minLength value="2"/>
				<xs:maxLength value="2"/>
				<xs:enumeration value="01"/>
				<xs:enumeration value="02"/>
				<xs:enumeration value="03"/>
				<xs:enumeration value="04"/>
				<xs:enumeration value="05"/>
				<xs:enumeration value="06"/>
				<xs:enumeration value="07"/>
				<xs:enumeration value="08"/>
				<xs:enumeration value="09"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="hoofdstuk.nr02">
		<xs:annotation>
			<xs:documentation>Nummer van een hoofdstuk 02 (altijd vaste waarde 02)</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:minLength value="0"/>
				<xs:maxLength value="2"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="hoofdstuk.nr1099" type="gen.codetweecijferspeciaal">
		<xs:annotation>
			<xs:documentation>Nummer van een hoofdstuk van 10 t/m 99</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="hoofdstuk.naam" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>naam van een hoofdstuk</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="deelhoofdstuk.nr" type="gen.codeeencijferalgemeen" default="0">
		<xs:annotation>
			<xs:documentation>Nummer van een deelhoofdstuk</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="deelhoofdstuk.naam" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>naam van een deelhoofdstuk</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="paragraaf1.nr">
		<xs:annotation>
			<xs:documentation>Nummer van een paragraaf (eencijferig en voorafgegaan door deelhoofdstuknr)</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="Character">
				<xs:pattern value="[1-7]"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="paragraaf2.nr">
		<xs:annotation>
			<xs:documentation>Nummer van een paragraaf (tweecijferig)</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:length value="2"/>
				<xs:pattern value="[0-9][0-9]"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="paragraaf.naam" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>naam van een paragraaf</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="paragraaf.leeg" type="xs:string" fixed="(In deze Standaard zijn geen bepalingen opgenomen, behorend tot deze paragraaf.)">
		<xs:annotation>
			<xs:documentation>Tekst indien bij een paragraaf geen tekst is opgenomen</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="artikel.nr" type="gen.codetweecijferalgemeen">
		<xs:annotation>
			<xs:documentation>Artikelnummer</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="artikel.hoofd" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>naam van een artikel</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="proef.nr">
		<xs:annotation>
			<xs:documentation>Proefnummer</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:minLength value="1"/>
				<xs:maxLength value="6"/>
				<xs:pattern value="[1-9][0-9]{0,2}(\.([1-9][0-9]?|0)|A|B)?"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="proef.naam" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>naam van een proef</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="lid.nr" type="gen.codetweecijferalgemeen">
		<xs:annotation>
			<xs:documentation>lid.nr</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:annotation>
		<xs:documentation>
    ================== Elementen voor systematiekspecifieke toevoegingen aan tabellen en figuren =====================  
 </xs:documentation>
	</xs:annotation>
	<xs:element name="tabel.volgnr" type="gen.codeeenoftweecijfer">
		<xs:annotation>
			<xs:documentation>Volgnummer van een tabel</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="tabel.naam" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>Beschrijving of naam bij een tabel</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="tabel.voettekst" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>Voettekst bij een tabel</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="figuur.naam" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>Beschrijving of naam bij een figuur</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="tabel.aanduiding">
		<xs:annotation>
			<xs:documentation>tabel.aanduiding: nummer en naam van een tabel.
Hoofdstuknummer en tabelnummer zijn niet verplicht. In de Handleiding komen tabellen voor met alleen een naam.</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:choice minOccurs="0">
					<xs:element ref="hoofdstuk.nr0109"/>
					<xs:element ref="proef.nr"/>
					<xs:element ref="hoofdstuk.nr1099"/>
				</xs:choice>
				<xs:element ref="tabel.volgnr" minOccurs="0"/>
				<xs:element ref="tabel.naam"/>
				<xs:element ref="tabel.voettekst" minOccurs="0"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:annotation>
		<xs:documentation>
    ================== Catalogus attributen =====================  
		</xs:documentation>
	</xs:annotation>
	<xs:attribute name="lengte" type="xs:positiveInteger">
		<xs:annotation>
			<xs:documentation>Lengte van een door de gebruiker in te voeren tekst of waarde</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:annotation>
		<xs:documentation>
    ================== Catalogus elementen =====================  
	 </xs:documentation>
	</xs:annotation>
	<xs:element name="werkcategorie.nr" type="gen.codetweecijferalgemeen">
		<xs:annotation>
			<xs:documentation>RAW-werkcategorienummer</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="werkcategorie.naam" type="gen.naamkort">
		<xs:annotation>
			<xs:documentation>Naam van een RAW-werkcategorie</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="subwerkcategorie.naam" type="gen.naamkort">
		<xs:annotation>
			<xs:documentation>Naam van een RAW-subwerkcategorie</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="hoofdcode.volgnr" type="gen.codetweecijferalgemeen">
		<xs:annotation>
			<xs:documentation>RAW-hoofdcodevolgnummer</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="romptekst" type="gen.naamkort" nillable="false">
		<xs:annotation>
			<xs:documentation>de verkorte naam (romptekst) van een RAW-hoofdcodevan een overeenkomst of de omschrijving van een staartpost</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="subwerkcategorie.nr" type="gen.codetweecijferalgemeen">
		<xs:annotation>
			<xs:documentation>RAW-subwerkcategorienummer</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="hoofdcode.hoofdtekst" type="hoofdcode.hoofdtekst" nillable="false">
		<xs:annotation>
			<xs:documentation>de (uitgebreide) naam van een RAW-hoofdcode</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="hoofdcode.tekstblok" type="tekstblok.catalogus">
		<xs:annotation>
			<xs:documentation>Het blok binnen een hoofdcode voorafgaand aan de deficode</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="bestekschrijvers.invultekst">
		<xs:annotation>
			<xs:documentation>Element waarbinnen de bestekschrijver kleine stukjes eigen tekst kan invullen</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attribute name="lengte" use="required">
						<xs:simpleType>
							<xs:restriction base="xs:positiveInteger"/>
						</xs:simpleType>
					</xs:attribute>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="bestekschrijvers.vrijetekst">
		<xs:annotation>
			<xs:documentation>Element waarbinnen de bestekschrijver eigen tekst kan invullen</xs:documentation>
		</xs:annotation>
		<xs:complexType mixed="true">
			<xs:complexContent>
				<xs:extension base="tekstblok.eenvoudig">
					<xs:attribute name="lengte" type="xs:positiveInteger" default="500"/>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="deficode.positie">
		<xs:annotation>
			<xs:documentation>Alle deficode-inhouden binnen één positieworden binnen dit element gegroepeerd</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="deficode.inhoud" maxOccurs="99"/>
				<xs:element ref="aanwijzings.tekst" minOccurs="0"/>
			</xs:sequence>
			<xs:attribute name="positienr" type="deficode.positienr" use="required"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="deficode.inhoud" nillable="false">
		<xs:annotation>
			<xs:documentation>Inhoud van een deficode</xs:documentation>
		</xs:annotation>
		<xs:complexType mixed="true">
			<xs:complexContent>
				<xs:extension base="tekstblok.catalogus">
					<xs:attribute name="inhoudnr" use="required">
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:minLength value="1"/>
								<xs:maxLength value="2"/>
								<xs:pattern value="(-)|[1-8]([1-8])*"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:attribute>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:annotation>
		<xs:documentation>   ================== Bouwstof elementen =====================  
	 </xs:documentation>
	</xs:annotation>
	<xs:element name="bouwstof">
		<xs:annotation>
			<xs:documentation>aanduiding van een bouwstof</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="bouwstof.omschr"/>
				<xs:element ref="eenheid"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="bouwstof.omschr" type="tekstblok.catalogus">
		<xs:annotation>
			<xs:documentation>omschrijving van een bouwstof</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:annotation>
		<xs:documentation>=================== Handleiding elementen ===================</xs:documentation>
	</xs:annotation>
	<xs:element name="hnl.tekst" type="tekstblok.hnl">
		<xs:annotation>
			<xs:documentation> handleidingtekst gekoppeld aan de boom</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:annotation>
		<xs:documentation>
			================== Formule elementen =====================
		</xs:documentation>
	</xs:annotation>
	<xs:element name="formule">
		<xs:complexType>
			<xs:choice>
				<xs:element ref="mathml"/>
			</xs:choice>
		</xs:complexType>
	</xs:element>
	<xs:element name="mathml">
		<xs:complexType>
			<xs:choice>
				<xs:element ref="m:math"/>
			</xs:choice>
		</xs:complexType>
	</xs:element>
	<xs:element name="proeven2025">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="proef.nr"/>
				<xs:element ref="proef.naam" maxOccurs="unbounded"/>
				<xs:element ref="versie.informatie" minOccurs="0"/>
				<xs:element ref="paragraafproef2025" minOccurs="0" maxOccurs="unbounded"/>
				<xs:element ref="proef.bijzonderheden" minOccurs="0"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="paragraafproef2025">
		<xs:annotation>
			<xs:documentation>Paragraaf van de 11 deling in de proeven</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="proefparagraafnr2025"/>
				<xs:element ref="paragraaf.naam"/>
				<xs:element ref="proeftekst"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="proefparagraafnr2025" type="gen.codeeenoftweecijfer">
		<xs:annotation>
			<xs:documentation>nummer van de 11 deling in de proeven</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="proef.bijzonderheden">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="paragraaf.naam"/>
				<xs:element ref="proeftekst"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="proeftekst" type="tekstblok.vrij"/>
</xs:schema>
