 </xs:documentation>
	</xs:annotation>
	<xs:simpleType name="guid">
		<xs:annotation>
			<xs:documentation>type guid: GUID string containing A-F 0-9 36 long</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[a-fA-F\d]{8}-([a-fA-F\d]{4}-){3}[a-fA-F\d]{12}"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:attribute name="guid" type="guid">
		<xs:annotation>
			<xs:documentation>attribuut dat kan worden gebruikt voor de unieke identificatie van elementen</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:element name="br" type="gen.leegelement">
		<xs:annotation>
			<xs:documentation>XMTML1 (afgeleid): Geforceerd regeleinde (zachte return)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="sup" type="xs:string">
		<xs:annotation>
			<xs:documentation>XMTML1 (afgeleid): Superscript (verhoogde tekst)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="sub" type="xs:string">
		<xs:annotation>
			<xs:documentation>XMTML1 (afgeleid): Subscript (verlaagde tekst)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="em" type="xs:string">
		<xs:annotation>
			<xs:documentation>XMTML1 (afgeleid): Emphasis:
element gebruikt om iets te benadrukken (en anders weer te geven) bij: (V/V) cursief (zie Hfd 31). Dit is niet bedoeld voor proefverwijzingen</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:annotation>
		<xs:documentation>
    ================== Imported names (XHTML1)  ===============================
    </xs:documentation>
	</xs:annotation>
	<xs:simpleType name="Character">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): a single character, as per section 2.2 of [XML]</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:length value="1" fixed="true"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="Length">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): nn for pixels or nn% for percentage length</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[-+]?(\d+|\d+(\.\d+)?%)"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="Number">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): one or more digits      </xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:nonNegativeInteger">
			<xs:pattern value="[0-9]+"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="MultiLength">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): pixel, percentage, or relative</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[-+]?(\d+|\d+(\.\d+)?%)|[1-9]?(\d+)?\*"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="Pixels">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): integer representing length in pixels</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:nonNegativeInteger"/>
	</xs:simpleType>
	<xs:simpleType name="StyleSheet">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): Style sheet data</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string"/>
	</xs:simpleType>
	<xs:simpleType name="Text">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): Used for titles etc.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string"/>
	</xs:simpleType>
	<xs:simpleType name="URI">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): a Uniform Resource Identifier, see [RFC2396]</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:anyURI"/>
	</xs:simpleType>
	<xs:annotation>
		<xs:documentation>
    ================== Generic Attributes (XHTML1) ===============================
    </xs:documentation>
	</xs:annotation>
	<xs:attributeGroup name="coreattrs">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): core attributes common to most elements
      id       document-wide unique id
      class    space separated list of classes
      style    associated style info
      title    advisory title/amplification      </xs:documentation>
		</xs:annotation>
		<xs:attribute name="id" type="xs:ID"/>
		<xs:attribute name="class" type="xs:string"/>
		<xs:attribute name="style" type="StyleSheet"/>
		<xs:attribute name="title" type="Text"/>
	</xs:attributeGroup>
	<xs:annotation>
		<xs:documentation>
    ================== Lists (XHTML1) ===========================================
</xs:documentation>
	</xs:annotation>
	<xs:element name="li" type="tekstblok.uitgebreid.std">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): List item: item binnen een opsomming</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ol">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): Ordered (numbered) list: opsomming met getallen of letters</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="li" maxOccurs="unbounded"/>
			</xs:sequence>
			<xs:attributeGroup ref="coreattrs"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="ul">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): Unordered list: lijst met opsommingstekens</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="li" maxOccurs="unbounded"/>
			</xs:sequence>
			<xs:attributeGroup ref="coreattrs"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="li.eenvoudig" type="tekstblok.uitgebreid.std">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): List item: item binnen een opsomming</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ol.eenvoudig">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): Ordered (numbered) list: opsomming met getallen of letters</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="li.eenvoudig" minOccurs="0" maxOccurs="unbounded"/>
			</xs:sequence>
			<xs:attributeGroup ref="coreattrs"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="ul.eenvoudig">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): Unordered list: lijst met opsommingstekens</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="li.eenvoudig" minOccurs="0" maxOccurs="unbounded"/>
			</xs:sequence>
			<xs:attributeGroup ref="coreattrs"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="li.catalogus" type="tekstblok.lijst.cat.res">
		<xs:annotation>
			<xs:documentation>XMTHl1: (afgeleid): Unordered list: lijst met opsommingstekens</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ol.catalogus">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): Ordered (numbered) list: opsomming met getallen of letters</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="li.catalogus" maxOccurs="unbounded"/>
