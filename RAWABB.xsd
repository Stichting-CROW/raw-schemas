	<xs:complexType name="tekstblok.alinea.vastvrij">
		<xs:annotation>
			<xs:documentation>De vaste en variabele teksten binnen een alinea in een hoofdcode of inschrijvingsdocument</xs:documentation>
		</xs:annotation>
		<xs:choice maxOccurs="unbounded">
			<xs:element ref="hoofdcode.vastetekst"/>
			<xs:element ref="hoofdcode.vrijetekst"/>
			<xs:element ref="hoofdcode.invultekst"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.eenvoudig" mixed="true">
		<xs:annotation>
			<xs:documentation>Elementen van dit type kunnen diverse andere elementen bevatten</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.regelopmaak"/>
			<xs:group ref="grp.supersub"/>
			<xs:element ref="alinea.inschrijvingsdocument"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.hoofdcode">
		<xs:annotation>
			<xs:documentation>De vaste en variabele tekstblokken binnen een hoofdcode</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:choice maxOccurs="unbounded">
				<xs:element ref="alinea.hoofdcode"/>
				<xs:group ref="grp.lijsten.hoofdcode"/>
				<xs:group ref="grp.tables.eenvoudig"/>
				<xs:element ref="aanwijzings.tekst"/>
			</xs:choice>
			<!--<xs:element ref="aanwijzings.tekst" minOccurs="0" />-->
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="tekstblok.hoofdcode.titel">
		<xs:annotation>
			<xs:documentation>De (uitgebreide) naam van een RAW-hoofdcode</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:choice maxOccurs="unbounded">
				<xs:element ref="hoofdcode.titel.vastetekst"/>
				<xs:element ref="hoofdcode.titel.vrijetekst"/>
			</xs:choice>
			<xs:element ref="aanwijzings.tekst" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="tekstblok.naamlang" mixed="true">
		<xs:annotation>
			<xs:documentation>De elementen die voor kunnen komen in de naam van een artikel, een figuur, een proef of een tabel.</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.supersub"/>
			<xs:group ref="grp.regelopmaak"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.titel" mixed="true">
		<xs:annotation>
			<xs:documentation>De elementen die kunnen voorkomen in de een titel element van een resultaatsbeschrijving</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.supersub"/>
			<xs:group ref="grp.overig"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.uitgebreid" mixed="true">
		<xs:annotation>
			<xs:documentation>Elementen van dit type kunnen diverse andere opmaakelementen bevatten</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:element ref="aanwijzings.tekst" minOccurs="0"/>
			<xs:group ref="grp.supersub" minOccurs="0"/>
			<xs:element ref="alinea.paragraaf" minOccurs="0"/>
			<xs:element ref="br" minOccurs="0"/>
		</xs:choice>
	</xs:complexType>
	<xs:complexType name="tekstblok.vrij" mixed="true">
		<xs:annotation>
			<xs:documentation>Elementen van dit type kunnen diverse andere opmaakelementen bevatten, dit tekstblok kan tevens 4 niveaus van koppen bevatten ivm proeven en bijlagen bij hoofdstukken</xs:documentation>
		</xs:annotation>
		<xs:choice minOccurs="0" maxOccurs="unbounded">
			<xs:group ref="grp.lists"/>
			<xs:group ref="grp.tables"/>
			<xs:group ref="grp.regelopmaak"/>
			<xs:group ref="grp.supersub"/>
			<xs:element ref="formule"/>
		</xs:choice>
	</xs:complexType>
	<xs:simpleType name="Character">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): a single character, as per section 2.2 of [XML]</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:length value="1" fixed="true"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="deficode.inhoudnr">
		<xs:annotation>
			<xs:documentation>Deficode inhoud nummer</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[1-9][1-9]?"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="deficode.positienr">
		<xs:annotation>
			<xs:documentation>De mogelijke waarde waarmee een deficodekolom kan worden aangeduid</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="1"/>
			<xs:enumeration value="2"/>
			<xs:enumeration value="3"/>
			<xs:enumeration value="4"/>
			<xs:enumeration value="5"/>
			<xs:enumeration value="6"/>
			<xs:enumeration value="12"/>
			<xs:enumeration value="23"/>
			<xs:enumeration value="34"/>
			<xs:enumeration value="45"/>
			<xs:enumeration value="56"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="eenheid">
		<xs:annotation>
			<xs:documentation>Eenheid</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[a-zA-Z1-9/*.]{0,4}"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="eenheid.zondereuro">
		<xs:annotation>
			<xs:documentation>Eenheid zonder EUR eenheid.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[a-zA-Z1-9/*.]{0,4}"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="gen.codeeencijferalgemeen">
		<xs:annotation>
			<xs:documentation>Een eencijferige code van 0 t/m 9</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:length value="1"/>
			<xs:pattern value="[0-9]"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="gen.codeeencijferspeciaal">
		<xs:annotation>
			<xs:documentation>Een eencijferige code van 1 t/m 9</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:length value="1"/>
			<xs:pattern value="[1-9]"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="gen.codeeenoftweecijfer">
		<xs:annotation>
			<xs:documentation>Een eencijferige of tweecijferige code van 0 t/m 99</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:minLength value="1"/>
			<xs:maxLength value="2"/>
			<xs:pattern value="[0-9]([0-9])*"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="gen.codetweecijferalgemeen">
		<xs:annotation>
			<xs:documentation>Een tweecijferige code van 00 t/m 99</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:length value="2"/>
			<xs:pattern value="[0-9][0-9]"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="gen.codetweecijferspeciaal">
		<xs:annotation>
			<xs:documentation>Een tweecijferige code van 10 t/m 99</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:length value="2"/>
			<xs:pattern value="[1-9][0-9]"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="gen.naamkort" final="restriction">
		<xs:annotation>
			<xs:documentation>Naam van 100 alfanumerieke posities</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:normalizedString">
			<xs:minLength value="1"/>
			<xs:maxLength value="100"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="gen.naamlang">
		<xs:annotation>
			<xs:documentation>Naam (geen lengtebeperking)</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string"/>
	</xs:simpleType>
	<xs:simpleType name="gencodetweecijfer0199">
		<xs:annotation>
			<xs:documentation>Een tweecijferige code 01 t/m 99, 0 op tweede positie is niet toegestaan</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[0-9][1-9]"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="hoev.2decimalen">
		<xs:restriction base="xs:decimal">
			<xs:fractionDigits value="2"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="hoev.2decimalen.positief">
		<xs:restriction base="hoev.2decimalen">
			<xs:minInclusive value="0"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="Length">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): nn for pixels or nn% for percentage length</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[-+]?(\d+|\d+(\.\d+)?%)"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="MultiLength">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): pixel, percentage, or relative</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[-+]?(\d+|\d+(\.\d+)?%)|[1-9]?(\d+)?\*"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="Number">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): one or more digits      </xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:nonNegativeInteger">
			<xs:pattern value="[0-9]+"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="Pixels">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): integer representing length in pixels</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:nonNegativeInteger"/>
	</xs:simpleType>
	<xs:simpleType name="StyleSheet">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): Style sheet data</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string"/>
	</xs:simpleType>
	<xs:simpleType name="Text">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): Used for titles etc.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string"/>
	</xs:simpleType>
	<xs:simpleType name="TFrame">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): 
      The border attribute sets the thickness of the frame around the
      table. The default units are screen pixels.

      The frame attribute specifies which parts of the frame around
      the table should be rendered. The values are not the same as
      CALS to avoid a name clash with the valign attribute.
      </xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="void"/>
			<xs:enumeration value="above"/>
			<xs:enumeration value="below"/>
			<xs:enumeration value="hsides"/>
			<xs:enumeration value="lhs"/>
			<xs:enumeration value="rhs"/>
			<xs:enumeration value="vsides"/>
			<xs:enumeration value="box"/>
			<xs:enumeration value="border"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="TRules">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): 
      The rules attribute defines which rules to draw between cells:

      If rules is absent then assume:
          "none" if border is absent or border="0" otherwise "all"
      </xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="none"/>
			<xs:enumeration value="groups"/>
			<xs:enumeration value="rows"/>
			<xs:enumeration value="cols"/>
			<xs:enumeration value="all"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="URI">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): a Uniform Resource Identifier, see [RFC2396]</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:anyURI"/>
	</xs:simpleType>
	<xs:group name="grp.lijsten.hoofdcode">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op opsommingen</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="lijst.hoofdcode"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.lists">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op opsommingen</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="ul"/>
			<xs:element ref="ol"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.lists.eenvoudig">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op eenvoudige opsommingen</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="ul.eenvoudig"/>
			<xs:element ref="ol.eenvoudig"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.overig">
		<xs:annotation>
			<xs:documentation>Groep met elementen die niet in een andere groep kunnen worden ondergebracht</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="em"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.regelopmaak">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op de regelopmaak</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="br"/>
			<xs:element ref="em"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.supersub">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op het super / sub weergeven van tekst</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element ref="sup" maxOccurs="unbounded"/>
			<xs:element ref="sub" maxOccurs="unbounded"/>
		</xs:choice>
	</xs:group>
	<xs:group name="grp.tables">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op de diverse onderdelen van tabellen</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element ref="tabel.aanduiding" minOccurs="0"/>
			<xs:element ref="table"/>
			<xs:element ref="tabel.voettekst" minOccurs="0"/>
		</xs:sequence>
	</xs:group>
	<xs:group name="grp.tables.eenvoudig">
		<xs:annotation>
			<xs:documentation>Groep met elementen die betrekking hebben op de diverse onderdelen van tabellen</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element ref="tabel.aanduiding" minOccurs="0"/>
			<xs:element ref="tabel.eenvoudig"/>
			<xs:element ref="tabel.voettekst" minOccurs="0"/>
		</xs:sequence>
	</xs:group>
</xs:schema>
