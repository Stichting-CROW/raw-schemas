<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.50 17/12/2025">
	<xs:annotation>
		<xs:documentation>Het framework voor de losse sjablonen van het ABB</xs:documentation>
	</xs:annotation>
	<!--contractvormen-->
	<xs:element name="raw.bestek">
		<xs:annotation>
			<xs:documentation>De definitie van de sjabloon voor het bestek</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="raw.contractinfo"/>
				<xs:element ref="dlx.koptekst"/>
				<xs:element ref="dlx.voor.compleet"/>
				<xs:element ref="dl1.compleet"/>
				<xs:element ref="dl2.compleet"/>
				<xs:element ref="dl3.compleet"/>
				<xs:element ref="dlx.na.compleet"/>
				<xs:element ref="dlx.voor.inschrijving.compleet"/>
				<xs:element ref="dlx.inschrijvingsbiljet"/>
				<xs:element ref="dlx.voorblad.inschrijvingsstaat"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="raw.bestek.nr" type="xs:string">
		<xs:annotation>
			<xs:documentation>het besteknummer in RAW</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="raw.nvi">
		<xs:annotation>
			<xs:documentation>De definitie van de sjabloon voor de nota van inlichtingen voor een bestek</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="raw.contractinfo.orig"/>
				<xs:element ref="dlx.koptekst" minOccurs="0"/>
				<xs:element ref="dlx.voor.compleet" minOccurs="0"/>
				<xs:element ref="dl1.compleet" minOccurs="0"/>
				<xs:element ref="dl2.compleet.nvi" minOccurs="0"/>
				<xs:element ref="dl3.compleet" minOccurs="0"/>
				<xs:element ref="dlx.na.compleet" minOccurs="0"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="raw.raamovereenkomst">
		<xs:annotation>
			<xs:documentation>De definitie van de sjabloon voor de raamovereenkomst</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="raw.contractinfo"/>
				<xs:element ref="dlx.koptekst"/>
				<xs:element ref="dlx.voor.compleet"/>
				<xs:element ref="dl1.compleet"/>
				<xs:element ref="dl2.compleet.ro"/>
				<xs:element ref="dl3.compleet"/>
				<xs:element ref="dlx.na.compleet"/>
				<xs:element ref="dlx.voor.inschrijving.compleet"/>
				<xs:element ref="dlx.inschrijvingsbiljet"/>
				<xs:element ref="dlx.voorblad.inschrijvingsstaat"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="raw.nvi.ro">
		<xs:annotation>
			<xs:documentation>De definitie van de sjabloon voor de nota van inlichtingen voor de raamovereenkomst</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="raw.contractinfo.orig"/>
				<xs:element ref="dlx.koptekst"/>
				<xs:element ref="dlx.voor.compleet"/>
				<xs:element ref="dl1.compleet"/>
				<xs:element ref="dl2.compleet.nvi.ro"/>
				<xs:element ref="dl3.compleet"/>
				<xs:element ref="dlx.na.compleet"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="raw.deelopdracht.raamovereenkomst">
		<xs:annotation>
			<xs:documentation>De dfinitie van de sjabloon voor de deelopdracht van een raampovereenkomst</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="raw.contractinfo.orig"/>
				<xs:element ref="dlx.koptekst"/>
				<xs:element ref="dlx.voor.compleet"/>
				<xs:element ref="dl2.compleet.do"/>
				<xs:element ref="dlx.na.compleet"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="raw.inschrijvingsstaat.raamovereenkomst">
		<xs:annotation>
			<xs:documentation>De definitie van de sjabloon voor de inschrijvingsstaat van een raamovereenkomst</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
                <xs:element ref="raw.contractinfo.orig" minOccurs="0"/> <!-- Optional for Fonto -->
				<xs:element ref="dlx.koptekst"/>
				<xs:element ref="ins.stt.voorblad"/>
				<xs:element ref="ins.stt.voorsubtot.ro"/>
				<xs:element ref="ins.stt.staart.ro"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<!--attributes en elementen-->
	<xs:attribute name="aard">
		<xs:annotation>
			<xs:documentation>
        L = aannemer moet bouwstof leveren
        T = bouwstof wordt door opdrachtgever ter beschiking gesteld
        I = Ter inlichting
        H = hergebruik zonder bewerking R= hergebruik na bewerking
			</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="L"/>
				<xs:enumeration value="T"/>
				<xs:enumeration value="I"/>
				<xs:enumeration value="H"/>
				<xs:enumeration value="R"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="eenheid.bouwstof" type="eenheid">
		<xs:annotation>
			<xs:documentation>De eenheid bij de bouwstof</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="eenheidwijzigbaar">
		<xs:annotation>
			<xs:documentation>Attribuut waarmee wordt aangegeven of de eenheid mag worden gemuteerd</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="ja"/>
				<xs:enumeration value="nee"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="hoev.bouwstof" type="hoev.2decimalen">
		<xs:annotation>
			<xs:documentation>hoeveelheid bouwstof</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="inspring" type="xs:positiveInteger">
		<xs:annotation>
			<xs:documentation>
        Attribuut dat de positie bepaalt van het eerste karakter.
        De positie wordt in 1/10 mm weergegeven.
        Dit attribuut moet worden gebruikt bij alineas.
			</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="invultype">
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="besteknummer"/>
				<xs:enumeration value="toelichting"/>
				<xs:enumeration value="omschrijving"/>
				<xs:enumeration value="reglement"/>
				<xs:enumeration value="omschrijvingperceel"/>
				<xs:enumeration value="inschrijverbedrijfa"/>
				<xs:enumeration value="inschrijvernaama"/>
				<xs:enumeration value="inschrijverfunctiea"/>
				<xs:enumeration value="inschrijverplaatsa"/>
				<xs:enumeration value="inschrijverkvknummera"/>
				<xs:enumeration value="inschrijverbedrijfb"/>
				<xs:enumeration value="inschrijvernaamb"/>
				<xs:enumeration value="inschrijverfunctieb"/>
				<xs:enumeration value="inschrijverplaatsb"/>
				<xs:enumeration value="inschrijverkvknummerb"/>
				<xs:enumeration value="inschrijverbedrijfc"/>
				<xs:enumeration value="inschrijvernaamc"/>
				<xs:enumeration value="inschrijverfunctiec"/>
				<xs:enumeration value="inschrijverplaatsc"/>
				<xs:enumeration value="inschrijverkvknummerc"/>
				<xs:enumeration value="aannemingssomexclusiefcijfers"/>
				<xs:enumeration value="aannemingssomexclusiefletters"/>
				<xs:enumeration value="omzetbelastingcijfers"/>
				<xs:enumeration value="omzetbelastingletters"/>
				<xs:enumeration value="ondertekeningdatum"/>
				<xs:enumeration value="ondertekeningplaats"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="kenmerk"/>
	<xs:attribute name="lijst.item.bullettype">
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="decimaal"/>
				<xs:enumeration value="klein_letter"/>
				<xs:enumeration value="groot_letter"/>
				<xs:enumeration value="klein_romein"/>
				<xs:enumeration value="groot_romein"/>
				<xs:enumeration value="rond"/>
				<xs:enumeration value="open_rond"/>
				<xs:enumeration value="blok"/>
				<xs:enumeration value="open_blok"/>
				<xs:enumeration value="ster"/>
				<xs:enumeration value="pijl"/>
				<xs:enumeration value="vink"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="lijst.item.inspringen" type="xs:unsignedInt"/>
	<xs:attribute name="lijst.item.start" type="xs:unsignedInt"/>
	<xs:attribute name="lijst.item.suffix">
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="punt"/>
				<xs:enumeration value="haakje"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="lijst.item.tekstbreedte" type="xs:unsignedInt"/>
	<xs:attribute name="lijst.item.tekstpositie" type="xs:unsignedInt"/>
	<xs:attribute name="muteren">
		<xs:annotation>
			<xs:documentation>geeft aan of tekst mag worden gemuteerd</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:pattern value="ja|nee"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="paginaeinde">
		<xs:annotation>
			<xs:documentation>
        Attribuut waarmee wordt aangegeven of het betreffende element op een nieuwe pagina moet beginnen
			</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="ja"/>
				<xs:enumeration value="nee"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="tabposities">
		<xs:annotation>
			<xs:documentation>attribuut dat mogelijkheid bied tabposities uit te wisselen</xs:documentation>
		</xs:annotation>
	</xs:attribute>
	<xs:attribute name="uitbreiden">
		<xs:annotation>
			<xs:documentation>geeft aan of delen tekst mogen worden uitgebreid met bijvoorbeel dmeer paragrafen</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:pattern value="ja|nee"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="verwijderen">
		<xs:annotation>
			<xs:documentation>geeft aan of een tekst of paragraaf o.i.d. mag worden verwijdern</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:pattern value="ja|nee"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="wijzigingspost">
		<xs:annotation>
			<xs:documentation>Attribuut waarmee wordt aangegeven of een post een wijzigingspost is</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="ja"/>
				<xs:enumeration value="nee"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attributeGroup name="cellhalign">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): 
      horizontal alignment attributes for cell contents

      char        alignment char, e.g. char=':'
      charoff     offset for alignment char
      </xs:documentation>
		</xs:annotation>
		<xs:attribute name="cellhalign">
			<xs:simpleType>
				<xs:restriction base="xs:string">
					<xs:enumeration value="left"/>
					<xs:enumeration value="center"/>
					<xs:enumeration value="right"/>
					<xs:enumeration value="justify"/>
					<xs:enumeration value="char"/>
				</xs:restriction>
			</xs:simpleType>
		</xs:attribute>
		<xs:attribute name="char" type="Character"/>
		<xs:attribute name="charoff" type="Length"/>
	</xs:attributeGroup>
	<xs:attributeGroup name="cellvalign">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): 
      vertical alignment attributes for cell contents
      </xs:documentation>
		</xs:annotation>
		<xs:attribute name="cellvalign">
			<xs:simpleType>
				<xs:restriction base="xs:string">
					<xs:enumeration value="top"/>
					<xs:enumeration value="middle"/>
					<xs:enumeration value="bottom"/>
					<xs:enumeration value="baseline"/>
					<xs:enumeration value="center"/>
				</xs:restriction>
			</xs:simpleType>
		</xs:attribute>
	</xs:attributeGroup>
	<xs:attributeGroup name="coreattrs">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): core attributes common to most elements
      id       document-wide unique id
      class    space separated list of classes
      style    associated style info
      title    advisory title/amplification      </xs:documentation>
		</xs:annotation>
		<xs:attribute name="id" type="xs:ID"/>
		<xs:attribute name="class" type="xs:string"/>
		<xs:attribute name="style" type="StyleSheet"/>
		<xs:attribute name="title" type="Text"/>
	</xs:attributeGroup>
	<xs:element name="aanwijzings.tekst" type="tekstblok.aanwijzings.tekst">
		<xs:annotation>
			<xs:documentation>Element waarmee aanwijzingen kunnen worden toegevoegd</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="alinea.hoofdcode">
		<xs:annotation>
			<xs:documentation>Element die een alinea voorstelt in deel22 waaraan een bouwstof gekoppeld kan worden</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:complexContent>
				<xs:extension base="tekstblok.alinea.vastvrij">
					<xs:attribute ref="inspring"/>
					<xs:attribute ref="tabposities"/>
					<xs:attribute ref="eenheid.bouwstof"/>
					<xs:attribute ref="eenheidwijzigbaar"/>
					<xs:attribute ref="hoev.bouwstof"/>
					<xs:attribute ref="aard"/>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="alinea.inschrijvingsdocument">
		<xs:annotation>
			<xs:documentation>tekstplaats voor inschrijivngsdocument</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:choice maxOccurs="unbounded">
				<xs:element ref="hoofdcode.vastetekst"/>
				<xs:element ref="hoofdcode.vrijetekst"/>
				<xs:element ref="hoofdcode.invultekst"/>
			</xs:choice>
		</xs:complexType>
	</xs:element>
	<xs:element name="alinea.paragraaf" type="tekstblok.uitgebreid">
		<xs:annotation>
			<xs:documentation>tekstelement voor de sjablonen</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="artikel.hoofd" type="tekstblok.naamlang">
		<xs:annotation>
			<xs:documentation>naam van een artikel</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="artikel.nr" type="gen.codetweecijferalgemeen">
		<xs:annotation>
			<xs:documentation>Artikelnummer</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="behoort.tot.raamovk" nillable="false">
		<xs:annotation>
			<xs:documentation>element dat aangeeft of een bestekspost bij aanbesteding tot een bestek behoort (waarde = ja) of later is toegevoegd (waarde = nee) als de waarde '0' is betreft het een bestekspost die is toegevoegd aan de deelopdracht maar niet in de raamovk wordt overgenomen.</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="ja"/>
				<xs:enumeration value="nee"/>
				<xs:enumeration value="0"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="bestekschrijvers.invultekst">
		<xs:annotation>
			<xs:documentation>Element waarbinnen de bestekschrijver kleine stukjes eigen tekst kan invullen</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attribute name="lengte" use="required">
						<xs:simpleType>
							<xs:restriction base="xs:positiveInteger"/>
						</xs:simpleType>
					</xs:attribute>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="bestekschrijvers.vrijetekst">
		<xs:annotation>
			<xs:documentation>Element waarbinnen de bestekschrijver eigen tekst kan invullen</xs:documentation>
		</xs:annotation>
		<xs:complexType mixed="true">
			<xs:complexContent>
				<xs:extension base="tekstblok.eenvoudig">
					<xs:attribute name="lengte" type="xs:positiveInteger" default="500"/>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="bpl.artikel">
		<xs:annotation>
			<xs:documentation>Definitie van een artikel uit de cat.bepalingen</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="artikel.nr" minOccurs="0"/> <!-- Optional for Fonto, added in export -->
				<xs:element ref="versie.informatie" minOccurs="0"/>
				<xs:element ref="artikel.hoofd" minOccurs="0"/> <!-- Optional for Fonto, added in export -->
				<xs:element ref="bpl.lid" maxOccurs="99"/>
			</xs:sequence>
			<xs:attribute ref="tabposities"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="bpl.hoofdstuk0109"/>
	<xs:element name="bpl.hoofdstuk1099"/>
	<xs:element name="bpl.lid">
		<xs:annotation>
			<xs:documentation>Definitie van een lid uit de cat.bepalingen</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="lid.nr"/>
				<xs:element ref="bpl.lidtekst"/>
			</xs:sequence>
			<xs:attribute ref="tabposities"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="bpl.lidtekst" type="tekstblok.uitgebreid">
		<xs:annotation>
			<xs:documentation> tekst van een lid uit de cat. bepalingen - hier kan aanwijzingstekst voorkomen</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="bpl.paragraaf.hfd0109">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="paragraaf.nr2"/>
				<xs:element ref="paragraaf.naam"/>
				<xs:element ref="bpl.artikel" maxOccurs="99"/>
			</xs:sequence>
			<xs:attribute ref="tabposities"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="br" type="gen.leegelement">
		<xs:annotation>
			<xs:documentation>XMTML1 (afgeleid): Geforceerd regeleinde (zachte return)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="col">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): 
      col elements define the alignment properties for cells in
      one or more columns.

      The width attribute specifies the width of the columns, e.g.

          width=64        width in screen pixels
          width=0.5*      relative width of 0.5

      The span attribute causes the attributes of one
      col element to apply to more than one column.
      </xs:documentation>
		</xs:annotation>
		<xs:complexType mixed="true">
			<xs:attributeGroup ref="coreattrs"/>
			<xs:attribute name="span" type="Number" default="1"/>
			<xs:attribute name="width" type="MultiLength"/>
			<xs:attributeGroup ref="cellhalign"/>
			<xs:attributeGroup ref="cellvalign"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="colgroup">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): 
      colgroup groups a set of col elements. It allows you to group
      several semantically related columns together.
      </xs:documentation>
		</xs:annotation>
		<xs:complexType mixed="true">
			<xs:sequence>
				<xs:element ref="col" minOccurs="0" maxOccurs="unbounded"/>
			</xs:sequence>
			<xs:attributeGroup ref="coreattrs"/>
			<xs:attribute name="span" type="Number" default="1"/>
			<xs:attribute name="width" type="MultiLength"/>
			<xs:attributeGroup ref="cellhalign"/>
			<xs:attributeGroup ref="cellvalign"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="colspec">
		<xs:annotation>
			<xs:documentation>XHTML1 (afgeleid): </xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="deficode">
		<xs:annotation>
			<xs:documentation>Alle deficode-inhouden binnen één positie worden binnen dit element gegroepeerd</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="positie.nr" type="deficode.positienr"/>
				<xs:element name="inhoud.nr" type="deficode.inhoudnr"/>
				<xs:element ref="deficode.inhoud.tekst" maxOccurs="unbounded"/>
				<xs:element ref="aanwijzings.tekst" minOccurs="0"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="deficode.inhoud.tekst">
		<xs:annotation>
			<xs:documentation>Deficode inhoud tekst</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:complexContent>
				<xs:extension base="tekstblok.hoofdcode">
					<xs:attribute name="lengte" type="xs:positiveInteger" default="500"/>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="dl1.compleet">
		<xs:annotation>
			<xs:documentation>deel 1 van het bestek / raamovereenkomst</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="dlx.deel.naam"/>
				<xs:element ref="dlx.paragraaf" maxOccurs="unbounded"/>
			</xs:sequence>
			<xs:attribute ref="uitbreiden"/>
			<xs:attribute ref="tabposities"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="dl2.compleet">
		<xs:annotation>
			<xs:documentation>deel 2 van het bestek</xs:documentation>
